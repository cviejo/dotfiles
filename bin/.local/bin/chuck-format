#! /bin/bash
# shellcheck disable=2086
set -e

clang-format $1 | awk '
	# gensub/capture groups only available in gawk
	/<<<[^ ]/ {
		gsub(/<<</,"<<< ");
	}
	/[^ ]>>>/ {
		gsub(/>>>/," >>>");
	}
   hold {
		if (hold == "public") {
			# fixes clang splitting `public class` in two lines.
			sub(/^[[:space:]]*/, "&" "public ")
		} else {
			# fixes clang splitting `=>` in two lines, we just the
			# space to the next line and remove the `=` at the end 
			# of the previous line.
			sub(/\ =\s*$/, "", hold)
			sub(/>/, "=>")
			print hold
		}
		hold = ""
	}
	{
		gsub(/=\ >/,"=>");
		gsub(/=\ </,"=<");
		gsub(/=\s*>/, "=>");
		gsub(/\ ::/,"::");
		gsub(/@ =>/,"@=>");
		if ($0 ~ /(^|[ \t])repeat\(/) {
			gsub(/repeat\(/,"repeat (");
		}
		gsub(/--\ >/," -->");

		if ($0 == "public" || /=\s*$/) {
			hold = $0
		}
		else {
			print;
		}
	}'
